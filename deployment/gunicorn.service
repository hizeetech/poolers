[Unit]
Description=Gunicorn daemon for shop.stakenaija.ng (ASGI)
After=network.target

[Service]
Type=simple
User=stakenaija
Group=www-data
WorkingDirectory=/var/www/shop
ExecStart=/var/www/shop/env/bin/gunicorn --access-logfile - --workers 3 --worker-class uvicorn.workers.UvicornWorker --bind unix:/run/shop/shop.sock --umask 007 poolbetting.asgi:application
Restart=always
RestartSec=3
RuntimeDirectory=shop
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
