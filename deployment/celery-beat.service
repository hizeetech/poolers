[Unit]
Description=Celery Beat for PoolBetting
After=network.target

[Service]
Type=simple
User=stakenaija
Group=www-data
WorkingDirectory=/var/www/shop
ExecStart=/var/www/shop/env/bin/celery -A poolbetting beat -l INFO --scheduler django_celery_beat.schedulers:DatabaseScheduler
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
